# Apply MIRROR_PREFIX to an image reference for pulling
function resolve_pull_ref() {
    local image="$1"
    local full_image="${image}"
    local first_segment="${image%%/*}"

    if [[ "${image}" == *"/"* ]]; then
        [[ "${first_segment}" != *"."* ]] && full_image="docker.io/${image}"
    else
        full_image="docker.io/library/${image}"
    fi

    if [[ -n "${MIRROR_PREFIX}" ]]; then
        echo "${MIRROR_PREFIX}/${full_image}"
    else
        echo "${full_image}"
    fi
}

# Pull a single image, apply mirror prefix, tag back to original name.
# Returns 0 on success, 1 on failure.
function pull_and_tag() {
    local image="$1"
    local pull_ref
    pull_ref=$(resolve_pull_ref "${image}")

    echo "  Pulling: ${pull_ref}"
    if ! docker pull "${pull_ref}"; then
        echo "  FAILED: ${image}"
        return 1
    fi

    if [[ "${pull_ref}" != "${image}" ]]; then
        docker tag "${pull_ref}" "${image}"
    fi
    return 0
}

